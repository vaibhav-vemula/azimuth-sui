# ── Sui ───────────────────────────────────────────────────────────────────────
# Bech32 secret key, e.g. `sui keytool export --key-identity <addr>` → suiprivkey1...
SUI_PRIVATE_KEY=suiprivkey1...
SUI_NETWORK=testnet

# Filled in after `sui client publish` and the init scripts (see move/scripts).
PACKAGE_ID=0x...
REGISTRY_ID=0x...          # shared StationRegistry object
ACCESS_REGISTRY_ID=0x...   # shared AccessRegistry object (Seal)

# ── Station role ───────────────────────────────────────────────────────────────
IS_PRIMARY=false           # true on exactly one station — runs the image merger
HEARTBEAT_INTERVAL_MS=60000
POLL_INTERVAL_MS=15000
RUN_CRANK=true             # this client also cranks settle_poa_epoch when due

# ── Seal (premium tier) ────────────────────────────────────────────────────────
SEAL_THRESHOLD=2
# Optional: override the testnet Seal key servers (comma-separated object ids).
# Default is one verified independent testnet key server (threshold auto-capped to count).
# SEAL_KEY_SERVER_IDS=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75

# ── Walrus (HTTP publisher/aggregator — no SDK needed) ──────────────────────────
# WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# Path the Pygame UI reads (written atomically). Defaults to ground_station/.
# STATE_FILE=../ground_station/sui_state.json
AZIMUTH_SATELLITE=METEOR-M2-3   # the satellite this station is tuned to
