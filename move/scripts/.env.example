# Owner/deployer bech32 secret key (suiprivkey1...). Holds AdminCap + TreasuryCap.
SUI_PRIVATE_KEY=suiprivkey1...
SUI_NETWORK=testnet

# Filled in from `publish.sh` output:
PACKAGE_ID=0x...
REGISTRY_ID=0x...        # shared StationRegistry
TREASURY_CAP_ID=0x...    # TreasuryCap<AZM> (owned by deployer)
ADMIN_CAP_ID=0x...       # orbital_vault AdminCap (owned by deployer)
ACCESS_REGISTRY_ID=0x... # shared AccessRegistry (Seal)

# setup.mjs params
POOL_AMOUNT=100000000    # AZM base units minted into the reward pool
STAKE_AMOUNT=100         # AZM per station (must match registry stake_amount)
# Comma-separated station addresses to pre-fund with stake:
STATIONS=0xstation1,0xstation2

# register.mjs (run per-station, with that station's key)
LOCATION=New York, USA
