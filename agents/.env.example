# ── LLM (Anthropic Claude via Vercel AI SDK) ───────────────────────────────────
# Without this, agents run in heuristic fallback mode (still functional, no LLM).
ANTHROPIC_API_KEY=
AZIMUTH_MODEL_REASON=claude-sonnet-4-6   # negotiation / vision analysis (Opus 4.8 needs a newer AI SDK)
AZIMUTH_MODEL_FAST=claude-sonnet-4-6     # high-frequency planning loops

# ── MemWal (Walrus Memory) ─────────────────────────────────────────────────────
# Get these from the MemWal Playground: https://memory.walrus.xyz/
#   1) create an account  2) generate a delegate key for your agent
#   → you receive a hex private key, an account id, and a relayer/server URL.
# Install (separate, due to the Seal/sui-v2 peer): npm install @mysten-incubation/memwal --legacy-peer-deps
# If unset, agents use a local-JSON memory store at agents/.memory/ (same interface).
MEMWAL_KEY=                 # the delegate/private key hex (alias: MEMWAL_PRIVATE_KEY)
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=          # relayer URL
MEMWAL_NAMESPACE=azimuth-net

# ── Sui (read events + optional on-chain actions) ──────────────────────────────
SUI_NETWORK=testnet
PACKAGE_ID=0x...
REGISTRY_ID=0x...
# Optional: a station key so the Operator Agent can actually submit heartbeats.
SUI_PRIVATE_KEY=

# ── Walrus (report artifacts) ──────────────────────────────────────────────────
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# ── Stations / demo ────────────────────────────────────────────────────────────
STATION_ID=station-a                 # this station's id (operator)
STATION_IDS=station-a,station-b       # all stations the coordinator reasons over
WATCH_INTERVAL_MS=30000              # analyst poll interval in `watch` mode

# Satellites the agents track (comma-separated). Leads with the one you're using.
AZIMUTH_SATELLITES=METEOR-M2-3,NOAA-19,NOAA-18,ISS
