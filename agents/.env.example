# ── LLM (Anthropic Claude via Vercel AI SDK) ───────────────────────────────────
# Without this, agents run in heuristic fallback mode (still functional, no LLM).
ANTHROPIC_API_KEY=
AZIMUTH_MODEL_REASON=claude-opus-4-8     # negotiation / vision analysis
AZIMUTH_MODEL_FAST=claude-sonnet-4-6     # high-frequency planning loops

# ── MemWal (Walrus Memory) ─────────────────────────────────────────────────────
# Get these from the MemWal Playground (https://walrus.xyz/products/walrus-memory/).
# If unset, agents use a local-JSON memory store at agents/.memory/ (same interface).
MEMWAL_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=
MEMWAL_NAMESPACE=azimuth-net

# ── Sui (read events + optional on-chain actions) ──────────────────────────────
SUI_NETWORK=testnet
PACKAGE_ID=0x...
REGISTRY_ID=0x...
# Optional: a station key so the Operator Agent can actually submit heartbeats.
SUI_PRIVATE_KEY=

# ── Walrus (report artifacts) ──────────────────────────────────────────────────
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# ── Demo ───────────────────────────────────────────────────────────────────────
STATION_ID=station-a
